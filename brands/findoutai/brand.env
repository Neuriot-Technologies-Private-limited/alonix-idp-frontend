# ─────────────────────────────────────────────────────────────
# FindoutAI Brand Configuration
# Used by: vite --mode findoutai
# DO NOT commit secrets here. This file contains branding only.
# ─────────────────────────────────────────────────────────────

# Identity
VITE_BRAND_NAME="FindoutAI"
VITE_BRAND_SHORT_NAME="FA"
VITE_BRAND_TAGLINE="AI-Powered Document Intelligence for Every Enterprise"
VITE_BRAND_COPYRIGHT="FindoutAI Technologies Inc."

# Colors (light mode)
VITE_BRAND_PRIMARY_LIGHT="#7C3AED"
VITE_BRAND_PRIMARY_CONTAINER_LIGHT="#EDE9FE"

# Colors (dark mode)
VITE_BRAND_PRIMARY_DARK="#C4B5FD"
VITE_BRAND_PRIMARY_CONTAINER_DARK="#2E1065"

# Links
VITE_BRAND_SUPPORT_EMAIL="support@findoutai.com"
VITE_BRAND_SALES_EMAIL="sales@findoutai.com"
VITE_BRAND_WEBSITE_URL="https://findoutai.com"
VITE_BRAND_PRIVACY_URL="https://findoutai.com/privacy"
VITE_BRAND_TERMS_URL="https://findoutai.com/terms"

# Feature flags
VITE_BRAND_SHOW_PRICING="true"
VITE_BRAND_SHOW_LANDING="true"

# Assets Configuration
VITE_BRAND_LOGO_URL="/brand/logo.png"
VITE_BRAND_LOGO_ICON_URL="/brand/logo-icon.png"
VITE_BRAND_FAVICON_URL="/brand/favicon.png"
