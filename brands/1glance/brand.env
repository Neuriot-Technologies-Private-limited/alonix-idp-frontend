# ─────────────────────────────────────────────────────────────
# 1-Glance Brand Configuration
# Used by: vite --mode 1glance
# DO NOT commit secrets here. This file contains branding only.
# ─────────────────────────────────────────────────────────────

# Identity
VITE_BRAND_NAME="1-Glance"
VITE_BRAND_SHORT_NAME="1G"
VITE_BRAND_TAGLINE="The Digital Curator for Your Document Intelligence Platform"
VITE_BRAND_COPYRIGHT="Alonix Intelligence Systems"

# Colors (light mode)
VITE_BRAND_PRIMARY_LIGHT="#005ac1"
VITE_BRAND_PRIMARY_CONTAINER_LIGHT="#d8e2ff"

# Colors (dark mode)
VITE_BRAND_PRIMARY_DARK="#ADC6FF"
VITE_BRAND_PRIMARY_CONTAINER_DARK="#1E2B4B"

# Links
VITE_BRAND_SUPPORT_EMAIL="support@1glance.ai"
VITE_BRAND_WEBSITE_URL="https://1glance.ai"
VITE_BRAND_PRIVACY_URL="https://1glance.ai/privacy"
VITE_BRAND_TERMS_URL="https://1glance.ai/terms"

# Feature flags
VITE_BRAND_SHOW_PRICING="true"
VITE_BRAND_SHOW_LANDING="true"
