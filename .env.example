# Dev: omit VITE_API_BASE_URL to use same-origin `/api` (see vite.config.ts proxy → backend).
# Production: set to your API origin, e.g. https://api.example.com/api
# VITE_API_BASE_URL=https://api.example.com/api

# Optional Socket.IO (defaults to VITE_API_BASE_URL or current origin)
# VITE_SOCKET_URL=http://localhost:5005
# VITE_SOCKET_PATH=/socket.io
